# ══════════════════════════════════════════════
# NMT — .env.example | Fase 2
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env — está no .gitignore.
# ══════════════════════════════════════════════

# ── EXISTENTES (Fase 1) ──────────────────────
GROQ_API_KEY=gsk_...
SOURCE_LANG=pt
TARGET_LANG=en
TARGET_LANG_LABEL=Inglês
TTS_VOICE=en-US-ChristopherNeural
SERVER_HOST=0.0.0.0
MAX_CONNECTIONS=10
CHUNK_DURATION_MS=250
SILENCE_TIMEOUT_S=1.5

# ── BANCO DE DADOS ───────────────────────────
# Railway injeta automaticamente. Localmente, copie de Railway > PostgreSQL > Connect
DATABASE_URL=postgresql+asyncpg://postgres:BtPuSsgRuLVxrusuNDATFflaTVgULXcP@host:5432/nmt

# ── AUTENTICAÇÃO JWT ─────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_32_char_hex_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── ABACATEPAY ───────────────────────────────
# Cadastre em app.abacatepay.com — use sandbox para testes
ABACATEPAY_API_KEY=abt_...
ABACATEPAY_WEBHOOK_SECRET=your_webhook_secret_here
ABACATEPAY_BASE_URL=https://api.abacatepay.com/v1

# ── EMAIL (RESEND) ────────────────────────────
# Cadastre em resend.com — grátis até 3k emails/mês
RESEND_API_KEY=re_...
EMAIL_FROM=nmt@seudominio.com.br

# ── GERAL ────────────────────────────────────
FRONTEND_URL=https://nmt.up.railway.app
# development | production
ENVIRONMENT=development
